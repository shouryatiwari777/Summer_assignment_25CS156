Write a program to Print Armstrong numbers in a range
#include <stdio.h>
#include <math.h>

int main() {
    int low, high, num, originalNum, remainder, n;
    double result;

    printf("Enter lower limit: ");
    scanf("%d", &low);

    printf("Enter upper limit: ");
    scanf("%d", &high);

    printf("Armstrong numbers between %d and %d are:\n", low, high);

    for (num = low; num <= high; num++) {
        originalNum = num;
        n = 0;
        result = 0;

        // Count digits
        while (originalNum != 0) {
            originalNum /= 10;
            n++;
        }

        originalNum = num;

        // Calculate sum of digits raised to power n
        while (originalNum != 0) {
            remainder = originalNum % 10;
            result += pow(remainder, n);
            originalNum /= 10;
        }

        if ((int)result == num)
            printf("%d ", num);
    }

    return 0;
}